        { "type": "what is the latest LTS version of Node.js?" },
        { "wait": 3 },
        { "key": "Enter" },
        { "wait": 12 },
        { "type": "/undo" },
        { "wait": 3 },
        { "key": "Enter" },
        { "wait": 5 }
      ]
    },
    {
