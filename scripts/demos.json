{
  "settings": {
    "fontSize": 15,
    "width": 800,
    "height": 500,
    "theme": "Dracula",
    "typingSpeed": "150ms",
    "framerate": 15,
    "startupWait": 5,
    "exitWait": 2
  },
  "demos": [
    {
      "id": "agent",
      "category": "agents",
      "description": "Agent picker — browse and activate a built-in agent",
      "steps": [
        {
          "type": "/agent"
        },
        {
          "wait": 3
        },
        {
          "key": "Enter"
        },
        {
          "wait": 3
        },
        {
          "key": "Down"
        },
        {
          "wait": 0.5
        },
        {
          "key": "Down"
        },
        {
          "wait": 0.5
        },
        {
          "key": "Down"
        },
        {
          "wait": 0.5
        },
        {
          "key": "Up"
        },
        {
          "wait": 0.5
        },
        {
          "key": "Up"
        },
        {
          "wait": 0.5
        },
        {
          "key": "Enter"
        },
        {
          "wait": 8
        }
      ]
    },
    {
      "id": "chronicle",
      "category": "agents",
      "description": "Chronicle standup",
      "command": "/chronicle standup",
      "responseWait": 25
    },
    {
      "id": "delegate",
      "category": "agents",
      "description": "Delegate task to remote agent",
      "steps": [
        { "wait": 2 },
        { "type": "/delegate write unit tests for the app" },
        { "wait": 3 },
        { "key": "Enter" },
        { "wait": 8 },
        { "key": "Escape" },
        { "wait": 3 }
      ]
    },
    {
      "id": "fleet",
      "category": "agents",
      "description": "Fleet parallel subagents",
      "command": "/fleet run all test suites in parallel",
      "responseWait": 30
    },
    {
      "id": "ide",
      "category": "agents",
      "description": "Connect IDE workspace",
      "command": "/ide",
      "responseWait": 8
    },
    {
      "id": "research",
      "category": "agents",
      "description": "Deep research with citations",
      "command": "/research NEXTJS app deployment option pros and cons",
      "responseWait": 30
    },
    {
      "id": "sidekicks",
      "category": "agents",
      "description": "List available sidekicks",
      "command": "/sidekicks list",
      "responseWait": 8
    },
    {
      "id": "tasks",
      "category": "agents",
      "description": "View active background tasks",
      "command": "/tasks",
      "responseWait": 8
    },
    {
      "id": "login",
      "category": "authentication",
      "description": "Authenticate — select GitHub.com, then show device code",
      "steps": [
        { "type": "/login" },
        { "wait": 3 },
        { "key": "Enter" },
        { "wait": 3 },
        { "key": "Enter" },
        { "wait": 8 }
      ]
    },
    {
      "id": "logout",
      "category": "authentication",
      "description": "Show current user, then preview /logout (cancelled safely)",
      "steps": [
        {
          "type": "/user show"
        },
        {
          "wait": 3
        },
        {
          "key": "Enter"
        },
        {
          "wait": 5
        },
        {
          "type": "/logout"
        },
        {
          "wait": 3
        }
      ]
    },
    {
      "id": "user",
      "category": "authentication",
      "description": "Show current user then list all authenticated accounts",
      "steps": [
        {
          "type": "/user show"
        },
        {
          "wait": 3
        },
        {
          "key": "Enter"
        },
        {
          "wait": 5
        },
        {
          "type": "/user list"
        },
        {
          "wait": 3
        },
        {
          "key": "Enter"
        },
        {
          "wait": 5
        }
      ]
